{
  "name": "portfolio-website",
  "description": "Personal portfolio with RAG-powered chat. React, Vite, Node, OpenAI.",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc -b",
    "check": "npm run typecheck && npm run lint",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "security:check": "npm run check && npm run audit:prod",
    "server": "node server/index.js",
    "start:server": "node server/index.js",
    "sync-knowledge": "node server/scripts/sync-knowledge-from-source.js",
    "build-knowledge": "node server/scripts/build-knowledge.js",
    "dev:full": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run dev\"",
    "start": "npm run dev:full"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "gsap": "^3.14.2",
    "helmet": "^8.0.0",
    "mammoth": "^1.8.0",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
