# Required for chat and for building knowledge (never commit this file with real values)
OPENAI_API_KEY=
TAVILY_API_KEY=

# Optional
# PORT=3001
# OPENAI_MODEL=gpt-4o-mini
# RATE_LIMIT_MAX=20
# CORS_ORIGIN=https://yourdomain.com

# Chat retrieval (detail mode = phrases like "technical", "architecture", "in depth")
# RAG_TOP_K=3
# RAG_TOP_K_DETAIL=12
# RAG_MIN_SCORE=0.25
# RAG_MIN_SCORE_DETAIL=0.18

# After setting OPENAI_API_KEY, run: npm run rebuild-knowledge
# (or: npm run sync-knowledge; npm run build-knowledge in PowerShell)

# GitHub → RAG (build-knowledge)
# Create a PAT: https://github.com/settings/tokens — use "classic" with repo scope for private repos, or fine-grained with Contents read.
# GITHUB_TOKEN=                # paste token here (never commit real values); improves rate limits; raw + Contents API for private code
# GITHUB_FETCH_REPO=false      # skip all GitHub fetches (full tree + partial)
# GITHUB_FULL_TREE=true        # index filtered source tree per repo (server/lib/githubFullTreeIndex.js + server/lib/githubContentFetch.js)
# GITHUB_FULL_TREE_MAX_FILES=1500
# GITHUB_MAX_FILE_BYTES=200000
# GITHUB_FULL_TREE_MAX_CHARS=48000
# GITHUB_FULL_TREE_ALLOW_EXT=.ts,.tsx,.js,.py,.md   # comma list; omit for defaults
# GITHUB_FULL_TREE_DENY_SEGMENTS=node_modules,dist,build   # comma list; omit for defaults
# GITHUB_FETCH_DELAY_MS=50
# GITHUB_MAX_FILES_PER_REPO=12   # partial-fetch only (when GITHUB_FULL_TREE is off)
